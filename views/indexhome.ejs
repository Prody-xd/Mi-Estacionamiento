<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Home · Mi Estacionamiento</title>
    <link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
    <link rel="stylesheet" href="/resources/css/style.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/home"><i class='bx bxs-car'></i> Mi Estacionamiento</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item"><a class="nav-link active" aria-current="page" href="/home">Inicio</a></li>
            <% if (loggedin) { %>
            <li class="nav-item"><a class="nav-link" href="/mapa">Buscar Estacionamiento</a></li>
            <li class="nav-item"><a class="nav-link" href="/">Arrendatarios</a></li>
            <% } %>
          </ul>
          <div class="d-flex gap-2 align-items-center">
            <% if (loggedin) { %>
              <span class="text-dim d-none d-lg-inline">Hola, <strong class="text-accent"><%= name %></strong></span>
              <a href="/logout" class="btn btn-outline-danger">Salir</a>
            <% } else { %>
              <a href="/login" class="btn btn-outline-primary">Iniciar Sesión</a>
              <a href="/register" class="btn btn-primary">Registrarse</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <header class="hero">
      <div class="container">
        <span class="badge-soft mb-3 d-inline-block"><i class='bx bx-map-pin'></i> Estacionamientos en tiempo real</span>
        <h1>Encuentra tu estacionamiento<br>cuando lo necesites</h1>
        <p class="lead">Localiza espacios disponibles en el mapa, conoce su estado al instante y administra a los arrendatarios desde un solo lugar.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
          <% if (loggedin) { %>
            <a href="/mapa" class="btn btn-primary btn-lg"><i class='bx bx-map'></i> Buscar Estacionamiento</a>
            <a href="/" class="btn btn-outline-primary btn-lg"><i class='bx bx-list-ul'></i> Ver Arrendatarios</a>
          <% } else { %>
            <a href="/register" class="btn btn-primary btn-lg"><i class='bx bx-user-plus'></i> Crear cuenta</a>
            <a href="/login" class="btn btn-outline-primary btn-lg"><i class='bx bx-log-in'></i> Iniciar sesión</a>
          <% } %>
        </div>
      </div>
    </header>

    <!-- FEATURES -->
    <section class="container my-5">
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body text-center p-4">
              <i class='bx bx-current-location' style="font-size:2.5rem;color:var(--accent)"></i>
              <h5 class="mt-3">Geolocalización</h5>
              <p class="text-dim mb-0">Visualiza tu ubicación y los estacionamientos cercanos en el mapa.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body text-center p-4">
              <i class='bx bx-time-five' style="font-size:2.5rem;color:var(--accent)"></i>
              <h5 class="mt-3">Estado en vivo</h5>
              <p class="text-dim mb-0">Consulta si un estacionamiento está disponible u ocupado al instante.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100">
            <div class="card-body text-center p-4">
              <i class='bx bx-user-check' style="font-size:2.5rem;color:var(--accent)"></i>
              <h5 class="mt-3">Gestión simple</h5>
              <p class="text-dim mb-0">Registra y administra arrendatarios de forma rápida y ordenada.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ¿Quiénes somos? -->
    <section class="container my-5">
      <div class="card">
        <div class="card-body text-center p-5">
          <h3 class="section-title">¿Quiénes Somos? <i class='bx bx-moon text-accent'></i></h3>
          <p class="text-dim mb-0">Somos <strong>Sad WorldWide</strong>, un equipo de desarrolladores creando soluciones para tu día a día.</p>
        </div>
      </div>
    </section>

    <!-- Equipo (carrusel con placeholders) -->
    <section class="container my-5">
      <h4 class="section-title text-center mb-4">Equipo de trabajo</h4>
      <div id="carouselEquipo" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-inner">
          <div class="carousel-item active">
            <img src="https://picsum.photos/seed/alda/900/420" class="d-block w-100" alt="Alda">
          </div>
          <div class="carousel-item">
            <img src="https://picsum.photos/seed/dayan/900/420" class="d-block w-100" alt="Dayan">
          </div>
          <div class="carousel-item">
            <img src="https://picsum.photos/seed/mage/900/420" class="d-block w-100" alt="Mage">
          </div>
          <div class="carousel-item">
            <img src="https://picsum.photos/seed/edu/900/420" class="d-block w-100" alt="Edu">
          </div>
          <div class="carousel-item">
            <img src="https://picsum.photos/seed/diego/900/420" class="d-block w-100" alt="Diego">
          </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselEquipo" data-bs-slide="prev">
          <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Anterior</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselEquipo" data-bs-slide="next">
          <span class="carousel-control-next-icon" aria-hidden="true"></span>
          <span class="visually-hidden">Siguiente</span>
        </button>
      </div>
    </section>

    <footer class="site-footer">
      © <span id="y"></span> Mi Estacionamiento · Sad WorldWide
    </footer>

    <script>document.getElementById('y').textContent = new Date().getFullYear();</script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/js/bootstrap.bundle.min.js" integrity="sha384-pprn3073KE6tl6bjs2QrFaJGz5/SUsLqktiwsUTF55Jfv3qYSDhgCecCxMW52nD2" crossorigin="anonymous"></script>
  </body>
</html>
