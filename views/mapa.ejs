<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mapa</title>
    <script src="https://polyfill.io/v3/polyfill.min.js?features=default"></script>
    <script defer
    src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCWhJQzFB-EqHQmWxTl-tS0Be36hmD736w&callback=initMap">
</script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
<link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>
<link rel="stylesheet" href="/resources/css/style.css">
<script>
    let map;
    let marker;
    let watchID;
    let geoLoc;

    function initMap(){
        const myLatLng = {lat: -33.515888116102154, lng: -70.59817848819068};
        const myLatLng2 = {lat: -33.51655898713955, lng: -70.60007749218344};
        const myLatLng3 = {lat: -33.51680944441122, lng: -70.601423961091};
        const myLatLng4 = {lat: -33.51496677816206, lng: -70.5990743459828};
        const msjOcupado = 'Estacionamiento Ocupado'
        const msjDispo = 'Estacionamiento Disponible'
        const msjMiUbi = 'Esta es tu Ubicacion'

//, 
        map = new google.maps.Map(document.getElementById("map"),{
            zoom: 15,
            center: myLatLng,
        });
        marker = new google.maps.Marker({
            position: myLatLng,
            map,
            title: "Mi ubicacion",
            animation: google.maps.Animation.BOUNCE
        });
        marker.addListener('click', (googleMapsEvent) => {
          document.getElementById('infoMarker').innerHTML = msjMiUbi
        });
        marker2 = new google.maps.Marker({
            position: myLatLng2,
            map : map,
            title: "Estacionamiento 2",
            animation: google.maps.Animation.DROP
        });
        marker2.addListener('click', (googleMapsEvent) => {
          document.getElementById('infoMarker').innerHTML = msjDispo
        });
        marker3 = new google.maps.Marker({
            position: myLatLng3,
            map : map,
            title: "Estacionamiento 3",
            animation: google.maps.Animation.DROP
        });
        marker3.addListener('click', (googleMapsEvent) => {
          document.getElementById('infoMarker').innerHTML = msjOcupado
        });
        marker4 = new google.maps.Marker({
            position: myLatLng4,
            map : map,
            title: "Estacionamiento 4",
            animation: google.maps.Animation.DROP
        });
        marker4.addListener('click', (googleMapsEvent) => {
          document.getElementById('infoMarker').innerHTML = msjDispo
        });

        getPosition();
    }
    function getPosition() {
        if(navigator.geolocation){
            var options = {timeout:60000};
            geoLoc = navigator.geolocation;
            watchID = geoLoc.watchPosition(showLocationOnMap, errorHandler, options);
        }else{
            alert("Lo sentimos, el navegador no soporta la geolocalizacion");
        }
    }
    function showLocationOnMap(position) {
        var latitud = position.coords.latitude;
        var longitud = position.coords.longitude;
        console.log("Latitud : " + latitud + " Longitud: " + longitud);

        const myLatLng = { lat: latitud, lng: longitud };
        marker.setPosition(myLatLng);
        map.setCenter(myLatLng);
    }
    function errorHandler(err) {
        if(err.code == 1) {
            alert("Error: acceso denegado!");
        }else if( err.code == 2 ) {
            alert("Error: position no existe o no se encuentra");
        }
    //
    }
</script>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
          <a class="navbar-brand" href="/home"><i class='bx bxs-car'></i> Mi Estacionamiento</a>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><a class="nav-link" href="/home">Inicio</a></li>
              <li class="nav-item"><a class="nav-link" href="/">Arrendatarios</a></li>
              <li class="nav-item"><a class="nav-link active" aria-current="page" href="/mapa">Buscar Estacionamiento</a></li>
            </ul>
          </div>
        </div>
      </nav>

    <div class="container my-5">
      <div class="text-center mb-4">
        <span class="badge-soft mb-3 d-inline-block"><i class='bx bx-current-location'></i> Geolocalización</span>
        <h2 class="section-title">Buscar Estacionamiento</h2>
        <p class="text-dim mx-auto" style="max-width:720px">Aquí podrás ver tu ubicación. Para saber el estado de un estacionamiento, haz click sobre su marcador.</p>
      </div>

      <div id="map"></div>

      <div class="map-status">
        <span class="text-dim">Estado:</span>
        <h4 class="text-accent mb-0 mt-1" id="infoMarker">Esperando selección...</h4>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous"></script>
</body>
</html>