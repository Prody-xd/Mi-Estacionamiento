<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro · Mi Estacionamiento</title>
    <link href='https://unpkg.com/boxicons@2.1.2/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
    <link rel="stylesheet" href="/resources/css/style.css">
</head>
<body>
    <div class="auth-wrap">
        <div class="register-form">
            <div class="text-center mb-2">
                <i class='bx bxs-user-plus' style="font-size:2.5rem;color:var(--accent)"></i>
            </div>
            <h1>Crear Cuenta</h1>
            <p class="auth-sub">Completa tus datos para registrarte</p>
            <form action="/register" method="POST">
                <label for="user">Usuario</label>
                <input type="text" name="user" required>

                <label for="name">Nombre Completo</label>
                <input type="text" name="name" required>

                <label for="rol">Rol</label>
                <select name="rol" id="rol" class="select-css">
                    <option value="">Seleccione un Rol...</option>
                    <option value="arrendatario">Arrendatario</option>
                    <option value="propietario">Propietario</option>
                </select>

                <label for="pass">Contraseña</label>
                <input type="password" name="pass" required>

                <div class="auth-actions">
                    <a href="/home" class="btn-cancel">Cancelar</a>
                    <input type="submit" class="btn-save" value="Guardar">
                </div>
            </form>
            <div class="text-center mt-3">
                <a href="/login" class="text-dim" style="text-decoration:none">¿Ya tienes cuenta? Inicia sesión</a>
            </div>
        </div>
    </div>

    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <% if(typeof alert != "undefined") { %>
        <script>
            Swal.fire({
                title:'<%= alertTitle %>',
                text:'<%= alertMessage %>',
                icon:'<%= alertIcon %>',
                showConfirmButton: <%= showConfirmButton %>,
                timer: <%= timer %>
            }).then(()=>{
                window.location='/<%= ruta %>'
            })
        </script>
    <% } %>
</body>
</html>
